# Data directories
# Keep only CSV files directly under each source folder: data/raw/<source>/*.csv
# Ignore all other files/folders under each source folder (e.g. post/image folders)
data/raw/*/*
!data/raw/*/*.csv
!data/raw/*/.gitkeep

data/processed/image_processed/*
!data/processed/image_processed/.gitkeep
data/**/*.json

